{
  "name": "mediflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "MediFlow — adaptive medication scheduling, dosage tracking & smart reminders. iOS + Android.",
  "scripts": {
    "start": "pnpm --filter @mediflow/app start -- --clear",
    "dev": "pnpm --filter @mediflow/app dev",
    "android": "pnpm --filter @mediflow/app android",
    "ios": "pnpm --filter @mediflow/app ios",
    "web": "pnpm --filter @mediflow/app web",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "convex": "^1.17.0",
    "react-native-get-random-values": "^1.11.0",
    "expo": "~55.0.27",
    "react": "19.2.0",
    "react-native": "0.83.6"
  },
  "pnpm": {
    "overrides": {
      "expo-secure-store": "~55.0.14",
      "expo-auth-session": "~55.0.16",
      "expo-web-browser": "~55.0.16",
      "expo-crypto": "~55.0.0",
      "expo-linking": "~55.0.15"
    },
    "patchedDependencies": {
      "@kinde/js-utils@0.30.2": "patches/@kinde__js-utils@0.30.2.patch"
    }
  }
}
